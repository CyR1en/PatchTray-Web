# Copy to `.env.local` for local overrides (not committed).
# On Vercel: Project → Settings → Environment Variables (same names).
# Leave a destination empty / unset to keep [ pending ] / disabled UI.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

VITE_RELEASE_VERSION=0.1.0
VITE_RELEASE_STATE=public beta

# Destinations — empty = pending
VITE_DOWNLOAD_URL=
VITE_PRO_MONTHLY_CHECKOUT_URL=
VITE_PRO_LIFETIME_CHECKOUT_URL=
VITE_SUPPORT_EMAIL=
VITE_REPOSITORY_URL=
VITE_COMMUNITY_URL=
VITE_PRIVACY_URL=
VITE_TERMS_URL=

# Published Pro pricing (defaults in config.ts if unset)
VITE_PRO_MONTHLY_PRICE=$4.99
VITE_PRO_LIFETIME_PRICE=$29.99

# Optional override; if unset, config.ts uses the default requirements copy
# VITE_REQUIREMENTS_TEXT=
